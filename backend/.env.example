# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/policychat

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_MODERATION_MODEL=omni-moderation-latest
EMBED_DIM=1536

# JWT
JWT_SECRET=
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=7

# Quota & Limits
DAILY_QUERY_LIMIT=5

# Auth Provider
AUTH_PROVIDER=local

# Azure Entra (optional, used when AUTH_PROVIDER=azure_entra)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_JWKS_URL=
